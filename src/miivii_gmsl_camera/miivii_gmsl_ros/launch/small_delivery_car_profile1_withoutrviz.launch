<launch>  
  <node pkg="miivii_gmsl_camera" exec="miivii_gmsl_camera_node" name="miivii_gmsl_camera_node" output="screen">  
    <param name="video0.active" value="false"/>
    <param name="video1.active" value="false"/>
    <param name="video2.active" value="false"/>
    <param name="video3.active" value="true"/>
    <param name="video3.camera_res" value="2880x1860"/>
    <param name="video3.output_res" value="1280x1024"/>
  </node>
</launch>